# Platt Partners — Environment variables template
# Copy this to .env (never commit .env)
# Heroku: set with `heroku config:set KEY=value -a platt-partners`

# ─── App identity ──────────────────────────────────────────────────────────
NODE_ENV=development                          # development | staging | production
NEXTAUTH_URL=http://localhost:3000            # base URL of the Next.js app
NEXTAUTH_SECRET=                              # generate: openssl rand -base64 32
NEXT_PUBLIC_APP_URL=http://localhost:3000     # used in client components for absolute URLs

# ─── MongoDB Atlas ─────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/platt_partners?retryWrites=true&w=majority
MONGODB_DB_NAME=platt_partners

# ─── Microsoft 365 (Entra App registration) ────────────────────────────────
# Register an Entra app with delegated scopes:
#   User.Read, Mail.ReadWrite, Mail.Send, MailboxSettings.Read,
#   Files.Read.Selected, Calendars.ReadWrite, offline_access
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_PETER_PRIMARY_EMAIL=peter@plattpartners.com
MS_OUTREACH_FROM_EMAIL=peter@outreach.plattpartners.com

# ─── Apollo.io ─────────────────────────────────────────────────────────────
APOLLO_API_KEY=
APOLLO_RATE_LIMIT_PER_MINUTE=60               # adjust to Peter's plan
APOLLO_MOBILE_CREDITS_PER_LOOKUP=10

# ─── LinkedIn (no programmatic access — manual export only) ────────────────
# Metadata only; we never call LinkedIn from code.
LINKEDIN_RECRUITER_OWNER_EMAIL=peter@plattpartners.com
ONEDRIVE_CSV_WATCH_FOLDER=/PlattPartners/LinkedIn-Exports

# ─── Anthropic (Claude) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DRAFTING=claude-sonnet-4-6
ANTHROPIC_MODEL_CLASSIFIER=claude-haiku-4-5

# ─── Google Gemini ─────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL_BULK=gemini-2.5-flash

# ─── Voyage AI (embeddings) ────────────────────────────────────────────────
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3-lite

# ─── Vector DB (Phase 4 — pick one) ────────────────────────────────────────
# If Pinecone:
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=platt-knowledge
# If Atlas Vector Search: uses the same MONGODB_URI above

# ─── Google APIs (GA4, Search Console) ─────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GA4_PROPERTY_ID=
SEARCH_CONSOLE_SITE_URL=https://plattpartners.com/
NEXT_PUBLIC_GA_ID=                            # G-XXXXXXXX — fired client-side via _app.tsx

# ─── Cloudinary ────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Slack (human-in-the-loop approval pings) ──────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_APPROVAL_CHANNEL=#peter-approvals

# ─── Twilio (optional alt for SMS approvals) ───────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_PETER_NUMBER=

# ─── Upstash (rate limiting for public widget) ─────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Backblaze B2 (free 10GB for Mongo backups) ────────────────────────────
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=platt-partners-backups

# ─── Scheduled jobs auth ───────────────────────────────────────────────────
# Heroku Scheduler hits /api/jobs/<name> with this secret in the X-Job-Secret header
JOB_RUNNER_SECRET=                            # generate: openssl rand -hex 32

# ─── Public widget guardrails ──────────────────────────────────────────────
PUBLIC_WIDGET_RATE_LIMIT_PER_IP_PER_MINUTE=10
PUBLIC_WIDGET_RATE_LIMIT_PER_IP_PER_DAY=100
PUBLIC_WIDGET_MAX_INPUT_TOKENS_PER_SESSION=8000
PUBLIC_WIDGET_MAX_OUTPUT_TOKENS_PER_SESSION=1000
PUBLIC_WIDGET_DAILY_SPEND_KILL_SWITCH_USD=5

# ─── Feature flags ─────────────────────────────────────────────────────────
FEATURE_PUBLIC_WIDGET_ENABLED=false           # turn on after Phase 4
FEATURE_OUTREACH_ENABLED=false                # turn on after Phase 3 + warmup complete
FEATURE_BD_OUTREACH_ENABLED=false             # turn on after Phase 5
